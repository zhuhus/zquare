{
  "name": "zquare-ui-monorepo",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "pnpm -C play dev",
    "story": "pnpm --filter @zquare/playground storybook",
    "docs:dev": "pnpm --filter @zquare/docs dev",
    "docs:build": "cross-env NODE_ENV=production pnpm build && pnpm --filter @zquare/docs build",
    "test": "cross-env NODE_ENV=test pnpm --filter @zquare/components test",
    "build": "run-s build-hooks build-components",
    "build-components": "cross-env NODE_ENV=production pnpm --filter zquare build",
    "build-hooks": "cross-env NODE_ENV=production pnpm --filter @zquare/hooks build",
    "build:dev": "run-s build-components:dev",
    "build-components:dev": "cross-env NODE_ENV=development pnpm --filter zquare build:watch",
    "build-hooks:dev": "cross-env NODE_ENV=development pnpm --filter @zquare/hooks build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "peerDependencies": {
    "vue": "^3.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^9.0.13",
    "@types/gulp": "^4.0.18",
    "@types/jsdom": "^27.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.15.17",
    "@types/shelljs": "^0.8.16",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/tsconfig": "^0.7.0",
    "cross-env": "^7.0.3",
    "cssnano": "^7.1.1",
    "move-file-cli": "^3.0.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "^10.4.0",
    "release-it": "^19.0.2",
    "rimraf": "^6.0.1",
    "rollup-plugin-visualizer": "5.7.1",
    "sass": "^1.93.2",
    "sass-loader": "^16.0.5",
    "shelljs": "^0.10.0",
    "typescript": "~5.5.4",
    "unplugin-vue-macros": "^2.7.11",
    "vite": "^6.3.5",
    "vitest": "^3.1.3",
    "vue-tsc": "^2.2.8",
    "vue3-i18n": "^1.1.5"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@fortawesome/fontawesome-svg-core": "^6.5.2",
    "@fortawesome/free-solid-svg-icons": "^6.5.2",
    "@fortawesome/vue-fontawesome": "^3.0.8",
    "@vitejs/plugin-vue-jsx": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "@zquare/build-utils": "workspace:*",
    "@zquare/components": "workspace:*",
    "@zquare/constants": "workspace:*",
    "@zquare/hooks": "workspace:*",
    "@zquare/locale": "workspace:*",
    "@zquare/play": "workspace:*",
    "@zquare/theme-chalk": "workspace:*",
    "@zquare/utils": "workspace:*",
    "consola": "^2.15.3",
    "gulp": "^4.0.2",
    "lodash-es": "^4.17.21",
    "resize-observer-polyfill": "^1.5.1",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.2.47",
    "zquare": "workspace:*"
  }
}
