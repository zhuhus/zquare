{
  "compilerOptions": {
    "outDir": "dist",
    "target": "es2018",
    "module": "esnext",
    "baseUrl": ".",
    "sourceMap": false,
    "moduleResolution": "node",
    "allowJs": false,
    "strict": true,
    "noUnusedLocals": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "removeComments": false,
    "rootDir": ".",
    "types": [],
    "paths": {
      "@zquare/components": ["packages/components"],
      "@zquare/components/*": ["packages/components/*"],
      "@zquare/utils": ["packages/utils"],
      "@zquare/utils/*": ["packages/utils/*"],
      "@zquare/hooks": ["packages/hooks"],
      "@zquare/directives": ["packages/directives"],
      "@zquare/constants": ["packages/constants"],
      "@zquare/locale": ["packages/locale"],
      "@zquare/locale/*": ["packages/locale/*"],
      "zquare": ["packages/zquare"]
    },
    "preserveSymlinks": true
  }
}
